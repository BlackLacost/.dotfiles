# Basic Settings
set preview true
#set previewer ~/.local/bin/preview
set hidden true         # отбражать скрытые файлы по-умолчанию
set icons true          # TODO сделать иконки
#set color256           # TODO пока не вижу разницы, когда включаю
set drawbox true        # border для трех колонок

# Custom Functions
cmd open ${{
    case $(file --mime-type "$f" -b) in
        text/* | application/json)
            $EDITOR "$f"
            ;;
        video/*)
            xdg-open "$f" &
            ;;
        application/pdf)
            setsid zathura $fx &
            ;;
        *)
            #xdg-open "$f" > /dev/null 2>&1 &
            xdg-open "$f" &
            ;;
    esac
}}

cmd video_preview ${{
    CACHE=$(mktemp /tmp/thumb_cache.XXXXX)
    ffmpegthumbnailer -i "$f" -o $CACHE -s 0
    draw_img $CACHE && rm $CACHE
}}

cmd mkdir ${{
    printf "Directory Name: "
    read answer
    mkdir $answer
}}

cmd mkfile ${{
    printf "File Name: "
    read answer
    $EDITOR $answer
}}

cmd chmod ${{
    printf "Mode Bits: "
    read answer

    for file in "$fx"; do
        chmod $anser "$file"
    done
}}

cmd sudomkfile ${{
    printf "File Name: "
    read answer
    sudo $EDITOR $answer
}}

cmd setwallpaper %cp "$f" ~/.config/wall.png && feh --bg-scale "$f"

cmd delete ${{
    printf "%s\n\t" "$fx"
    printf "delete?[y/N]"
    read ans
    [ $ans = "y" ] && rm -rf $fx
}}

#Bindings
#Remove som defaults
map m

map o open
map <enter> shell
map <c-n> mkdir
map D delete
map A rename                # at the very end
map C push A<c-u>           # new rename
map I push A<c-a>           # at the very beginning
map i push A<a-b><a-b><a-f> # before extention
map a push A<a-b>           # after extention
map x cut
map y copy
map p paste
map c clear
map bg setwallpaper
map cm chmod
map mf mkfile
map . set hidden!
map - $draw_img $f
map + :video_preview

